Package: mrpheus
Title: Polysomnography Signal Analysis for Sleep Research
Version: 0.1.0.9000
Authors@R: c(
    person("Lucas", "França",
           email = "lucas.franca@northumbria.ac.uk",
           role = c("aut", "cre")),
    person("Mario", "Leocadio-Miguel",
           role = "aut",
           comment = c(ORCID = "0000-0002-7248-3529"))
